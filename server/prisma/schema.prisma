generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  ONRAMP
  TRANSFER
  MERCHANT_PAYMENT
}

model User {
  id                   String        @id @default(uuid())
  name                 String
  username             String        @unique
  password             String
  account              UserAccount?
  sentTransactions     Transaction[] @relation("SentTransactions")
  receivedTransactions Transaction[] @relation("ReceivedTransactions")
}

model UserAccount {
  id      String @id @default(uuid())
  balance Int    @default(0)
  locked  Int    @default(0)
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id])
}

model Merchant {
  id           String           @id @default(uuid())
  username     String           @unique
  password     String
  account      MerchantAccount?
  transactions Transaction[]
}

model MerchantAccount {
  id         String   @id @default(uuid())
  balance    Int      @default(0)
  locked     Int      @default(0)
  merchantId String   @unique
  merchant   Merchant @relation(fields: [merchantId], references: [id])
}

model Transaction {
  id           String          @id @default(uuid())
  amount       Int
  type         TransactionType
  fromUserId   String?
  toUserId     String?
  toMerchantId String?
  createdAt    DateTime        @default(now())
  fromUser     User?           @relation("SentTransactions", fields: [fromUserId], references: [id])
  toUser       User?           @relation("ReceivedTransactions", fields: [toUserId], references: [id])
  toMerchant   Merchant?       @relation(fields: [toMerchantId], references: [id])
}
